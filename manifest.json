{
  "manifest_version": 3,
  "name": "Universal Adblock Spoof",
  "version": "6.2",
  "description": "Uniwersalny spoof detekcji adblocka — działa na każdej stronie, wyłączalny per domena/adres.",
  "permissions": [
    "scripting",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Universal Adblock Spoof",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fake-scripts/*.js"
      ],
      "matches": [
        "*://*/*"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "adblock_spoof_rules",
        "enabled": true,
        "path": "rules/rules.json"
      }
    ]
  }
}
